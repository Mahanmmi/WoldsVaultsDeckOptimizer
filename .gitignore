# Rust build artifacts
ndm_core/target/

# Python cache
__pycache__/
*.pyc
*.pyo

# Compiled extension (users build this themselves)
*.pyd
*.so
*.whl

# Spreadsheet outputs
*.xlsx

# Python virtual environment
.venv/

# Claude Code worktrees + per-project metadata (they live inside the repo)
.claude/

# Scratch / smoke-test artifacts (local-only)
scratch_*.py
scratch_*.log
scratch_*.txt

# Web app
web/node_modules/
web/dist/
# Generated by scripts/build_data.py at build time
web/public/config.json
web/public/decks.json
web/public/modifiers.json
# Generated by wasm-pack
web/src/wasm/
web/src/wasm-node/
